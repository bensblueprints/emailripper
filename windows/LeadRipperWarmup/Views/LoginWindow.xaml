<Window x:Class="LeadRipperWarmup.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="LeadRipper Warmup"
        Width="460" Height="620"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
  <Grid Margin="40">
    <StackPanel VerticalAlignment="Center">
      <Border Width="56" Height="56" CornerRadius="14" Background="{StaticResource AccentGradient}" HorizontalAlignment="Left">
        <TextBlock Text="LR" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
      </Border>
      <TextBlock Text="LeadRipper Warmup" Style="{StaticResource H1}" Margin="0,20,0,4"/>
      <TextBlock Text="Sign in to access your campaigns, inboxes, and warming pool." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>

      <StackPanel Margin="0,24,0,0">
        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                 ui:ControlHelper.PlaceholderText="Email address"
                 Margin="0,0,0,10" Padding="12,10"/>
        <PasswordBox x:Name="PwBox" PasswordChanged="PwBox_OnPasswordChanged"
                     Padding="12,10"
                     ui:ControlHelper.PlaceholderText="Password"/>
        <StackPanel x:Name="RegisterExtras" Margin="0,10,0,0" Visibility="{Binding RegisterMode, Converter={StaticResource BoolToVis}}">
          <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" ui:ControlHelper.PlaceholderText="Full name" Padding="12,10" Margin="0,0,0,10"/>
          <TextBox Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}" ui:ControlHelper.PlaceholderText="Company" Padding="12,10"/>
        </StackPanel>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
      </StackPanel>

      <Button Content="Sign in" Command="{Binding SubmitCommand}" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" IsEnabled="{Binding Busy, Converter={StaticResource InverseBool}}"/>

      <Button Content="Create account" Background="Transparent" Foreground="{StaticResource AccentBrush}" BorderThickness="0" Margin="0,6,0,0" Command="{Binding ToggleModeCommand}" HorizontalAlignment="Center" Cursor="Hand"/>

    </StackPanel>
  </Grid>
</Window>
