<UserControl x:Class="LeadRipperWarmup.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             Background="{StaticResource SurfaceBrush}">
  <Grid Margin="32,28,32,40">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="320"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <StackPanel Grid.Column="0" Margin="0,0,16,0">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <TextBlock Text="Templates" Style="{StaticResource H2}" VerticalAlignment="Center"/>
        <Button Content="+ New" Margin="12,0,0,0" Command="{Binding NewCommand}"/>
      </StackPanel>
      <ListBox ItemsSource="{Binding Templates}" SelectedItem="{Binding Selected}" Background="Transparent" BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="12,10" Margin="0,0,0,4" CornerRadius="8" Background="#14FFFFFF">
              <StackPanel>
                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Subject}" Foreground="{StaticResource MutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
      <StackPanel>
        <TextBlock Text="Name" Style="{StaticResource MetricLabel}"/>
        <TextBox Text="{Binding Selected.Name}" Padding="10,8" Margin="0,0,0,10"/>
        <TextBlock Text="Subject" Style="{StaticResource MetricLabel}"/>
        <TextBox Text="{Binding Selected.Subject}" Padding="10,8" Margin="0,0,0,10"/>
        <TextBlock Text="Body HTML" Style="{StaticResource MetricLabel}"/>
        <TextBox Text="{Binding Selected.BodyHtml}" Padding="10,10" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="240" VerticalScrollBarVisibility="Auto"/>
        <Button Content="Save template" Style="{StaticResource PrimaryButton}" Margin="0,14,0,0" HorizontalAlignment="Left" Command="{Binding SaveCommand}"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
