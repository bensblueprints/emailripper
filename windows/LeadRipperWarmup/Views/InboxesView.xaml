<UserControl x:Class="LeadRipperWarmup.Views.InboxesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28,32,40">
    <StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
        <StackPanel>
          <TextBlock Text="Inboxes" Style="{StaticResource H1}"/>
          <TextBlock Text="Connect mailboxes to send from and include in the warming pool." Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>
      </StackPanel>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
        <Button Style="{StaticResource PrimaryButton}" Content="Connect Gmail" Command="{Binding ConnectGmailCommand}" Margin="0,0,10,0"/>
        <Button Style="{StaticResource PrimaryButton}" Content="Connect Microsoft 365" Command="{Binding ConnectMicrosoftCommand}" Margin="0,0,10,0"/>
        <Button Content="Add IMAP / SMTP" Padding="14,10"/>
        <Button Content="Add SMTP relay" Padding="14,10" Margin="10,0,0,0"/>
      </StackPanel>

      <ItemsControl ItemsSource="{Binding Inboxes}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Email}" FontWeight="SemiBold" Foreground="White" FontSize="15"/>
                    <Border Background="#14FFFFFF" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                      <TextBlock Text="{Binding Provider}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    </Border>
                  </StackPanel>
                  <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0">
                    <Run Text="status "/><Run Text="{Binding Status}"/>
                    <Run Text=" · reputation "/><Run Text="{Binding ReputationScore}"/>
                    <Run Text=" · warmup "/>
                    <Run Text="{Binding WarmupEnabled}"/>
                  </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Content="Remove" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
