<UserControl x:Class="LeadRipperWarmup.Views.WarmingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28,32,40">
    <StackPanel>
      <StackPanel Margin="0,0,0,24">
        <TextBlock Text="Inbox warming" Style="{StaticResource H1}"/>
        <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap">
          Each enabled inbox joins the peer warming pool. The scheduler sends short, human-looking
          messages between inboxes and rescues any that land in spam. Caps ramp up automatically as
          reputation improves.
        </TextBlock>
      </StackPanel>

      <ItemsControl ItemsSource="{Binding Inboxes}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
                  <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center"
                          Background="{Binding ReputationScore, Converter={StaticResource RepColor}}"/>
                  <TextBlock Text="{Binding Email}" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="10,0,0,0"/>
                  <Border Background="#14FFFFFF" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                    <TextBlock Text="{Binding Provider}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                  </Border>
                </StackPanel>

                <ToggleButton Grid.Column="1" Grid.Row="0"
                              IsChecked="{Binding WarmupEnabled, Mode=OneWay}"
                              Content="{Binding WarmupEnabled, Converter={StaticResource BoolToVis}, StringFormat='enabled'}"
                              Click="ToggleClicked" Tag="{Binding}"/>

                <!-- Metrics -->
                <UniformGrid Grid.ColumnSpan="2" Grid.Row="1" Columns="5" Margin="0,16,0,0">
                  <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabel}" Text="REPUTATION"/>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{Binding ReputationScore, Converter={StaticResource RepColor}}" Text="{Binding ReputationScore}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabel}" Text="TODAY / CAP"/>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White">
                      <Run Text="{Binding SentToday}"/><Run Text="/"/><Run Text="{Binding WarmupCurrentCap}"/>
                    </TextBlock>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabel}" Text="SENT 14D"/>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White" Text="{Binding Sent14d}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabel}" Text="REPLIED 14D"/>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" Text="{Binding Replied14d}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Style="{StaticResource MetricLabel}" Text="SPAM / RESCUED"/>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource WarnBrush}">
                      <Run Text="{Binding Spam14d}"/><Run Text=" / "/><Run Text="{Binding Rescued14d}"/>
                    </TextBlock>
                  </StackPanel>
                </UniformGrid>

                <!-- Config -->
                <Grid Grid.ColumnSpan="2" Grid.Row="2" Margin="0,16,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Daily min" Style="{StaticResource MetricLabel}"/>
                    <TextBox Text="{Binding WarmupDailyMin}" Padding="10,8"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Daily max" Style="{StaticResource MetricLabel}"/>
                    <TextBox Text="{Binding WarmupDailyMax}" Padding="10,8"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Ramp step" Style="{StaticResource MetricLabel}"/>
                    <TextBox Text="{Binding WarmupRampStep}" Padding="10,8"/>
                  </StackPanel>
                  <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="Reply rate (0-1)" Style="{StaticResource MetricLabel}"/>
                    <TextBox Text="{Binding WarmupReplyRate}" Padding="10,8"/>
                  </StackPanel>
                  <Button Grid.Column="4" Content="Save" VerticalAlignment="Bottom"
                          Style="{StaticResource PrimaryButton}" Click="SaveClicked" Tag="{Binding}"/>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="{Binding Error}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
