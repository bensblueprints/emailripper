<UserControl x:Class="LeadRipperWarmup.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             Background="{StaticResource SurfaceBrush}">
  <StackPanel Margin="32,28,32,40">
    <TextBlock Text="Settings" Style="{StaticResource H1}"/>
    <TextBlock Text="Account preferences." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,20"/>

    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="Account" Style="{StaticResource H2}" Margin="0,0,0,12"/>
        <TextBlock Text="Email" Style="{StaticResource MetricLabel}"/>
        <TextBox Text="{Binding Email, Mode=OneWay}" Padding="10,8" IsReadOnly="True" Margin="0,0,0,12"/>
        <TextBlock Text="Full name" Style="{StaticResource MetricLabel}"/>
        <TextBox Text="{Binding FullName}" Padding="10,8"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
