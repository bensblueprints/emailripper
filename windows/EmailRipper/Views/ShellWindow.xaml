<Window x:Class="EmailRipper.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        Title="Email Ripper"
        Width="1400" Height="900"
        MinWidth="1100" MinHeight="720"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Grid.Resources>
      <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FFD4D4DC"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="br" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="br" Property="Background" Value="#22FFFFFF"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </Grid.Resources>

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="#FF0A0A10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,32,20,24">
          <StackPanel Orientation="Horizontal">
            <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource AccentGradient}">
              <TextBlock Text="LR" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
              <TextBlock Text="LeadRipper" FontSize="13" Foreground="{StaticResource MutedBrush}"/>
              <TextBlock Text="Warmup" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="12,0">
          <Button x:Name="BtnDashboard" Style="{StaticResource NavButton}" Content="Dashboard" Tag="Dashboard" Click="NavClick"/>
          <Button x:Name="BtnCampaigns" Style="{StaticResource NavButton}" Content="Campaigns" Tag="Campaigns" Click="NavClick"/>
          <Button x:Name="BtnSequence"  Style="{StaticResource NavButton}" Content="Sequence builder" Tag="Sequence" Click="NavClick"/>
          <Button x:Name="BtnLeads"     Style="{StaticResource NavButton}" Content="Leads" Tag="Leads" Click="NavClick"/>
          <Button x:Name="BtnTemplates" Style="{StaticResource NavButton}" Content="Templates" Tag="Templates" Click="NavClick"/>
          <Separator Margin="12,16,12,8" Background="{StaticResource BorderBrush}"/>
          <Button x:Name="BtnInboxes"   Style="{StaticResource NavButton}" Content="Inboxes" Tag="Inboxes" Click="NavClick"/>
          <Button x:Name="BtnWarming"   Style="{StaticResource NavButton}" Content="Warming" Tag="Warming" Click="NavClick"/>
          <Separator Margin="12,16,12,8" Background="{StaticResource BorderBrush}"/>
          <Button x:Name="BtnAnalytics" Style="{StaticResource NavButton}" Content="Analytics" Tag="Analytics" Click="NavClick"/>
          <Button x:Name="BtnSettings"  Style="{StaticResource NavButton}" Content="Settings" Tag="Settings" Click="NavClick"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="20,0,20,24">
          <Border Style="{StaticResource CardStyle}" Padding="14">
            <StackPanel Orientation="Horizontal">
              <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource AccentGradient}">
                <TextBlock Text="{Binding UserInitial}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Margin="10,0,0,0" VerticalAlignment="Center" Width="140">
                <TextBlock Text="{Binding UserEmail}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Signed in" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              </StackPanel>
              <Button Content="⎋" Width="28" Height="28" Padding="0" Command="{Binding LogoutCommand}" ToolTip="Log out"/>
            </StackPanel>
          </Border>
        </StackPanel>

      </Grid>
    </Border>

    <!-- Content -->
    <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="{StaticResource SurfaceBrush}"/>
  </Grid>
</Window>
