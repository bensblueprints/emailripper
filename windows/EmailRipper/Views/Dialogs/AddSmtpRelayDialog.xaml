<Window x:Class="EmailRipper.Views.Dialogs.AddSmtpRelayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Add SMTP relay"
        Width="520" SizeToContent="Height"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="28">
    <TextBlock Text="Add SMTP relay" Style="{StaticResource H1}" FontSize="20"/>
    <TextBlock Text="SendGrid, Mailgun, Amazon SES, Postmark. Send-only (not included in warming pool)." Foreground="{StaticResource MutedBrush}" Margin="0,2,0,18" TextWrapping="Wrap"/>

    <TextBlock Text="From email" Style="{StaticResource MetricLabel}"/>
    <TextBox x:Name="EmailBox" Padding="10,8" Margin="0,4,0,10"/>

    <TextBlock Text="Display name (optional)" Style="{StaticResource MetricLabel}"/>
    <TextBox x:Name="DisplayBox" Padding="10,8" Margin="0,4,0,16"/>

    <Grid Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="120"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="SMTP host" Style="{StaticResource MetricLabel}"/>
        <TextBox x:Name="SmtpHostBox" Padding="10,8" Text="smtp.sendgrid.net"/>
      </StackPanel>
      <StackPanel Grid.Column="2">
        <TextBlock Text="Port" Style="{StaticResource MetricLabel}"/>
        <TextBox x:Name="SmtpPortBox" Padding="10,8" Text="587"/>
      </StackPanel>
    </Grid>
    <TextBlock Text="Username (often 'apikey' for SendGrid)" Style="{StaticResource MetricLabel}"/>
    <TextBox x:Name="SmtpUserBox" Padding="10,8" Margin="0,4,0,10" Text="apikey"/>
    <TextBlock Text="API key / password" Style="{StaticResource MetricLabel}"/>
    <PasswordBox x:Name="SmtpPassBox" Padding="10,8" Margin="0,4,0,10"/>
    <CheckBox x:Name="SmtpSecureBox" Content="SSL / TLS (use false for STARTTLS on 587)" Foreground="White" Margin="0,0,0,18"/>

    <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Padding="14,10" Margin="0,0,10,0" Click="OnCancel"/>
      <Button Style="{StaticResource PrimaryButton}" Content="Connect" Click="OnSave"/>
    </StackPanel>
  </StackPanel>
</Window>
