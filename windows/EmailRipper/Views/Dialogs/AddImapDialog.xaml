<Window x:Class="EmailRipper.Views.Dialogs.AddImapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Add IMAP / SMTP mailbox"
        Width="560" SizeToContent="Height"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="28">
    <TextBlock Text="Add IMAP / SMTP mailbox" Style="{StaticResource H1}" FontSize="20"/>
    <TextBlock Text="Connect any mailbox (Zoho, FastMail, cPanel, custom domain)." Foreground="{StaticResource MutedBrush}" Margin="0,2,0,18"/>

    <TextBlock Text="Email address" Style="{StaticResource MetricLabel}"/>
    <TextBox x:Name="EmailBox" Padding="10,8" Margin="0,4,0,10"/>

    <TextBlock Text="Display name (optional)" Style="{StaticResource MetricLabel}"/>
    <TextBox x:Name="DisplayBox" Padding="10,8" Margin="0,4,0,16"/>

    <TextBlock Text="IMAP (incoming)" Style="{StaticResource H2}" FontSize="14" Margin="0,0,0,8"/>
    <Grid Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="120"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Host" Style="{StaticResource MetricLabel}"/>
        <TextBox x:Name="ImapHostBox" Padding="10,8" Text="imap.gmail.com"/>
      </StackPanel>
      <StackPanel Grid.Column="2">
        <TextBlock Text="Port" Style="{StaticResource MetricLabel}"/>
        <TextBox x:Name="ImapPortBox" Padding="10,8" Text="993"/>
      </StackPanel>
    </Grid>
    <TextBlock Text="Username" Style="{StaticResource MetricLabel}"/>
    <TextBox x:Name="ImapUserBox" Padding="10,8" Margin="0,4,0,10"/>
    <TextBlock Text="Password / app password" Style="{StaticResource MetricLabel}"/>
    <PasswordBox x:Name="ImapPassBox" Padding="10,8" Margin="0,4,0,16"/>

    <TextBlock Text="SMTP (outgoing)" Style="{StaticResource H2}" FontSize="14" Margin="0,0,0,8"/>
    <Grid Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="120"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Host" Style="{StaticResource MetricLabel}"/>
        <TextBox x:Name="SmtpHostBox" Padding="10,8" Text="smtp.gmail.com"/>
      </StackPanel>
      <StackPanel Grid.Column="2">
        <TextBlock Text="Port" Style="{StaticResource MetricLabel}"/>
        <TextBox x:Name="SmtpPortBox" Padding="10,8" Text="465"/>
      </StackPanel>
    </Grid>
    <TextBlock Text="Username" Style="{StaticResource MetricLabel}"/>
    <TextBox x:Name="SmtpUserBox" Padding="10,8" Margin="0,4,0,10"/>
    <TextBlock Text="Password / app password" Style="{StaticResource MetricLabel}"/>
    <PasswordBox x:Name="SmtpPassBox" Padding="10,8" Margin="0,4,0,10"/>
    <CheckBox x:Name="SmtpSecureBox" Content="SSL / TLS on SMTP" Foreground="White" IsChecked="True" Margin="0,0,0,18"/>

    <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Padding="14,10" Margin="0,0,10,0" Click="OnCancel"/>
      <Button Style="{StaticResource PrimaryButton}" Content="Connect" Click="OnSave"/>
    </StackPanel>
  </StackPanel>
</Window>
