<UserControl x:Class="EmailRipper.Views.DomainsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             Background="{StaticResource SurfaceBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28,32,40">
    <StackPanel>
      <StackPanel Margin="0,0,0,16">
        <TextBlock Text="Domain warming" Style="{StaticResource H1}"/>
        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}">
          Track DNS health (SPF, DKIM, DMARC), aggregate reputation across every inbox on a sending domain, and ramp per-domain send volume so a fresh domain doesn't get blacklisted on day one.
        </TextBlock>
      </StackPanel>

      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Add a domain" Style="{StaticResource H2}" FontSize="15" Margin="0,0,0,10"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="200"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}" ui:ControlHelper.PlaceholderText="example.com" Padding="12,10" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1" Text="{Binding NewSelector, UpdateSourceTrigger=PropertyChanged}" ui:ControlHelper.PlaceholderText="DKIM selector (optional)" Padding="12,10" Margin="0,0,10,0"/>
            <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="Add" Command="{Binding AddCommand}" Margin="0,0,10,0"/>
            <Button Grid.Column="3" Content="Sync from inboxes" Command="{Binding SyncFromInboxesCommand}" Padding="14,10"/>
          </Grid>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding Error}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                 Visibility="{Binding Error, Converter={StaticResource NullToVisibilityConverter}}"/>

      <ItemsControl ItemsSource="{Binding Domains}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <Grid Margin="0,0,0,12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Domain}" FontWeight="SemiBold" Foreground="White" FontSize="16"/>
                      <Border Background="#14FFFFFF" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                          <Run Text="{Binding InboxCount}"/><Run Text=" inboxes"/>
                        </TextBlock>
                      </Border>
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0">
                      <Run Text="Reputation "/><Run Text="{Binding ReputationScore}"/>
                      <Run Text=" / cap "/><Run Text="{Binding CurrentCap}"/>
                      <Run Text="-"/><Run Text="{Binding MaxCap}"/>
                      <Run Text=" · step +"/><Run Text="{Binding RampStep}"/>
                    </TextBlock>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Check DNS" Command="{Binding DataContext.CheckCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="0,0,8,0"/>
                    <Button Content="Toggle warmup" Command="{Binding DataContext.ToggleWarmupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="0,0,8,0"/>
                    <Button Content="Remove" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                  </StackPanel>
                </Grid>

                <UniformGrid Columns="3">
                  <Border Background="#14FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                      <TextBlock Text="SPF" Style="{StaticResource MetricLabel}"/>
                      <TextBlock Text="{Binding SpfStatus, TargetNullValue='not checked'}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding SpfRecord}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="#14FFFFFF" CornerRadius="8" Padding="12" Margin="4,0,4,0">
                    <StackPanel>
                      <TextBlock Text="DKIM" Style="{StaticResource MetricLabel}"/>
                      <TextBlock Text="{Binding DkimStatus, TargetNullValue='unknown'}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding DkimSelector, StringFormat=selector: {0}, TargetNullValue='no selector set'}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  <Border Background="#14FFFFFF" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                    <StackPanel>
                      <TextBlock Text="DMARC" Style="{StaticResource MetricLabel}"/>
                      <TextBlock Text="{Binding DmarcStatus, TargetNullValue='not checked'}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding DmarcRecord}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                </UniformGrid>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
