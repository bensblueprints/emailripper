<UserControl x:Class="EmailRipper.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28,32,40">
    <StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
        <StackPanel>
          <TextBlock Text="Dashboard" Style="{StaticResource H1}"/>
          <TextBlock Text="Performance of your cold email program, at a glance." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>
        <Button Content="Refresh" Command="{Binding LoadCommand}" HorizontalAlignment="Right" Margin="24,8,0,0" Style="{StaticResource PrimaryButton}"/>
      </StackPanel>

      <!-- Metric cards -->
      <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
          <StackPanel>
            <TextBlock Style="{StaticResource MetricLabel}" Text="EMAILS SENT"/>
            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Totals.Sent, FallbackValue=0}"/>
            <TextBlock Foreground="{StaticResource MutedBrush}" Text="lifetime"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
          <StackPanel>
            <TextBlock Style="{StaticResource MetricLabel}" Text="OPEN RATE"/>
            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding OpenRate, StringFormat={}{0}%}"/>
            <TextBlock Foreground="{StaticResource SuccessBrush}" Text="{Binding Totals.Opened, StringFormat=+{0} opens}"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
          <StackPanel>
            <TextBlock Style="{StaticResource MetricLabel}" Text="REPLY RATE"/>
            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding ReplyRate, StringFormat={}{0}%}"/>
            <TextBlock Foreground="{StaticResource AccentBrush}" Text="{Binding Totals.Replied, StringFormat=+{0} replies}"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource MetricLabel}" Text="BOUNCE RATE"/>
            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding BounceRate, StringFormat={}{0}%}"/>
            <TextBlock Foreground="{StaticResource DangerBrush}" Text="{Binding Totals.Bounced, StringFormat={}{0} bounces}"/>
          </StackPanel>
        </Border>
      </UniformGrid>

      <!-- Grid: campaigns + warming -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0" Grid.Column="0">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
              <TextBlock Text="Recent campaigns" Style="{StaticResource H2}"/>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding RecentCampaigns}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="12,10" Margin="0,0,0,6" CornerRadius="8" Background="#14FFFFFF">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                          <Run Text="{Binding LeadCount}"/><Run Text=" leads · "/>
                          <Run Text="{Binding SentCount}"/><Run Text=" sent · "/>
                          <Run Text="{Binding RepliedCount}"/><Run Text=" replies"/>
                        </TextBlock>
                      </StackPanel>
                      <Border Grid.Column="1" Background="{StaticResource AccentGradient}" CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}" Grid.Column="1">
          <StackPanel>
            <TextBlock Text="Warming pool" Style="{StaticResource H2}" Margin="0,0,0,12"/>
            <ItemsControl ItemsSource="{Binding WarmupInboxes}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="12,10" Margin="0,0,0,6" CornerRadius="8" Background="#14FFFFFF">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding Email}" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                          <Run Text="{Binding SentToday}"/><Run Text="/"/><Run Text="{Binding WarmupCurrentCap}"/><Run Text=" today · rep "/>
                          <Run Text="{Binding ReputationScore}"/>
                        </TextBlock>
                      </StackPanel>
                      <Border Grid.Column="1" Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center"
                              Background="{Binding ReputationScore, Converter={StaticResource RepColor}}"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
