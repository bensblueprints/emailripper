NODE_ENV=development
PORT=4100

# Postgres
DATABASE_URL=postgresql://warmup:warmup@localhost:5432/warmup

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4100/api/oauth/google/callback

# Microsoft OAuth (365 / Outlook)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:4100/api/oauth/microsoft/callback

# Encryption key for storing OAuth tokens and IMAP passwords at rest (32-byte hex)
ENCRYPTION_KEY=

# CORS origins — native apps typically don't need CORS but electron dev does
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
